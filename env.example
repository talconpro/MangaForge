# =========================================================
# MangaForge Environment Variables
# Copy this file to .env and update values for your machine.
# =========================================================

# ---------------------------------------------------------
# App
# ---------------------------------------------------------
APP_ENV=development
APP_NAME=MangaForge
API_PREFIX=/api/v1
DEBUG=true

# ---------------------------------------------------------
# Frontend
# ---------------------------------------------------------
VITE_APP_NAME=MangaForge
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ---------------------------------------------------------
# Backend Server
# ---------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mangaforge
POSTGRES_USER=mangaforge
POSTGRES_PASSWORD=mangaforge_password

DATABASE_URL=postgresql+psycopg://mangaforge:mangaforge_password@postgres:5432/mangaforge

# Local backend without Docker can use:
# DATABASE_URL=postgresql+psycopg://mangaforge:mangaforge_password@localhost:5432/mangaforge

# ---------------------------------------------------------
# Redis
# ---------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# Local backend without Docker can use:
# REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------
# JWT
# ---------------------------------------------------------
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_SECONDS=86400

# ---------------------------------------------------------
# MinIO / S3 Compatible Storage
# ---------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=manga-forge
MINIO_SECURE=false

# Local backend without Docker can use:
# MINIO_ENDPOINT=localhost:9000

# ---------------------------------------------------------
# AI / LLM Provider
# ---------------------------------------------------------
LLM_PROVIDER=openai_compatible
LLM_API_BASE=https://api.example.com/v1
LLM_API_KEY=change_me
LLM_MODEL=gpt-4.1
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=8192
LLM_TIMEOUT_SECONDS=180

# ---------------------------------------------------------
# HermesAgent
# ---------------------------------------------------------
HERMES_AGENT_ENABLED=true
HERMES_AGENT_ENDPOINT=http://agent:9000
HERMES_AGENT_API_KEY=change_me
HERMES_AGENT_TIMEOUT_SECONDS=180

# If HermesAgent is not ready, backend can later support:
# AI_EXECUTOR=direct_llm
AI_EXECUTOR=hermes

# ---------------------------------------------------------
# Celery
# ---------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Local backend without Docker can use:
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------------------------------------------------------
# Upload Limits
# ---------------------------------------------------------
MAX_UPLOAD_FILE_SIZE_MB=50
ALLOWED_UPLOAD_EXTENSIONS=.txt

# ---------------------------------------------------------
# Export
# ---------------------------------------------------------
EXPORT_TEMP_DIR=/tmp/mangaforge/exports
EXPORT_FILE_EXPIRE_DAYS=30

# ---------------------------------------------------------
# Logging
# ---------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
